<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel = "stylesheet" href = "/styles/style.css">
</head>
<body class ="w-full">
   
    <div class = " p-1 overflow-hidden w-full min-h-screen bg-zinc-900">

       <div class = "p-10 text-white" class = "form">
        <form class = "text-color-white" action="/create" method = "post">
            <input class ="my-3 rounded-md outline-none block p-4 bg-zinc-800 w-full" type="text" placeholder = "Title goes here..." name = "Title">
            <textarea class = "my-3 rounded-md outline-none p-4 resize-none bg-zinc-800 w-full "placeholder = "write your task..." name = "Detail"></textarea>
            <input class = "m-1 bg-blue-600 rounded-md px-2 py-2" type = "submit" value = "Create Task">

        </form>
       </div>
       
       <div class = "tasks m-4 p-4 w-full flex flex-wrap gap-5">

       <% if(files.length > 0){ %>
          <% files.forEach(function(val){ %>
               <div class = "task w-70 p-4 bg-zinc-800 rounded-md ">
            <h1 class = "text-white text-3xl tracking -tighter"><%= val%> </h1>

           <div class="flex justify-between align-center m-2">
            <a class = "text-blue-500 inline-block " href="/file/<%=val%>">Read more..</a>
             <a href="/edit/<%=val%>" class = "bg-gray">edit filename</a>
             </div>
             
        </div>
        <%  }) %>

           
      <% }else{ %>
        <h3 class = "text-zinc-600">no tasks yet</h3>
     <% }%>
       
       
        
             
        </div>


        </div>

        

        

    


     <script src = "/javascripts/main.js"></script>
</body>
</html>