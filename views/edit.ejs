    <title>Document</title>
</head>
<body>
    <div class = "p-1 overflow-hidden w-full min-h-screen bg-zinc-900 text-white">
        <a class = "text-blue-500 inline-block m-10"href="/">Go Back to home</a>

     <form action="/edit" method = "post">

